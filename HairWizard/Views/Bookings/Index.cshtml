<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title m-0">Appointments</h1>
        <a asp-action="Add" class="btn btn-primary">New appointment</a>
    </div>

    <div class="table-soft p-3">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Treatment</th>
                    <th>Employee</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Customer</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model)
                {
                    <tr>
                        <td>@booking.Treatment.Name</td>
                        <td>@booking.Employee.Name</td>
                        <td>@booking.StartTime.ToString("dd-MM-yyyy HH:mm")</td>
                        <td>@booking.EndTime.ToString("HH:mm")</td>
                        <td>
                            @if (User.IsInRole("Admin") && booking.ApplicationUserId != null)
                            {
                                <a asp-controller="Customers"
                                   asp-action="Details"
                                   asp-route-id="@booking.ApplicationUserId">
                                    @booking.ApplicationUser?.FullName
                                </a>
                            }
                            else
                            {
                                @booking.ApplicationUser?.FullName
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@booking.BookingId" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@booking.BookingId" class="btn btn-sm btn-outline-danger"
                               onclick="return confirm('Are you sure you want to delete this appointment?')">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>