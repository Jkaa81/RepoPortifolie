@model BookingViewModel

@{
    string action = ViewBag.Action ?? string.Empty;
}

<div class="container my-5" style="max-width: 700px;">
    <div class="page-card">
        <h1 class="page-title">
            @(action == "edit" ? "Edit appointment" : "Book appointment")
        </h1>

        <form method="post" asp-controller="Bookings" asp-action="@action">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            @if (action == "edit")
            {
                <input type="hidden" asp-for="Booking.BookingId" />
                <input type="hidden" asp-for="Booking.ApplicationUserId" />
                <input type="hidden" asp-for="Booking.RowVersion" />
            }

            <div class="mb-3">
                <label asp-for="Booking.TreatmentId" class="form-label"></label>
                <select asp-for="Booking.TreatmentId"
                        asp-items="@(new SelectList(Model.Treatments, "TreatmentId", "Name", Model.Booking?.TreatmentId))"
                        class="form-select">
                    <option value="">- Please Select -</option>
                </select>
                <span asp-validation-for="Booking.TreatmentId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Booking.StartTime" class="form-label"></label>
                <input type="datetime-local" step="60" asp-for="Booking.StartTime" class="form-control" />
                <span asp-validation-for="Booking.StartTime" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Booking.EmployeeId" class="form-label"></label>
                <select asp-for="Booking.EmployeeId"
                        asp-items="@(new SelectList(Model.Employees, "EmployeeId", "Name", Model.Booking?.EmployeeId))"
                        class="form-select">
                    <option value="">- Please Select -</option>
                </select>
                <span asp-validation-for="Booking.EmployeeId" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save appointment</button>
                <a asp-controller="Bookings" asp-action="Index" class="btn btn-light border">Cancel</a>
            </div>
        </form>
    </div>
</div>