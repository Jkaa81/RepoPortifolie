@model List<Employee>

<div class="d-flex justify-content-between align-items-center mt-4 mb-4">
    <h1 class="mb-0">Employees:</h1>
</div>

<div class="d-flex flex-wrap gap-3">

    <table class="table">
        <tr>
            <th>Name</th>
            <th></th>
        </tr>
        @foreach (var employee in Model)
        {
            <tr>
                <th>@employee.Name</th>
            
                <th>
                    <a asp-controller="Bookings" asp-action="Add" asp-route-id="@employee.EmployeeId" class="btn btn-link">Book</a>
                </th>
            </tr>
        }
    </table>
</div>